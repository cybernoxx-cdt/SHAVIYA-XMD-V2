  "keywords": ["SHAVIYA-XMD-V2", "WhatsApp-Bot", "SHAVIYA-TECH"],
  "success_url": "/",
  "stack": "heroku-24",
  "env": {
    "SESSION_ID": {
      "description": "Your session ID — base64 encoded creds.json OR a MEGA link.",
