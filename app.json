    "ALIVE_IMG": {
      "description": "Alive command image URL",
      "required": false,
      "value": "https://files.catbox.moe/f18ceb.jpg"
    },
    "MENU_IMG": {
      "description": "Menu image URL",
      "required": false,
      "value": "https://files.catbox.moe/f18ceb.jpg"
    }
  },
  "buildpacks": [
    { "url": "https://github.com/heroku/heroku-buildpack-nodejs.git" }
